{
  "slug": "ai-signal-platform",
  "title": "AI Signal Platform Builder",
  "subtitle": "Generate internal tools from structured configuration without hardcoding every screen.",
  "theme": {
    "accent": "#0ea5e9",
    "accentSecondary": "#f97316",
    "surface": "#f7f4ee"
  },
  "metrics": [
    { "label": "Generated screens", "value": "14", "delta": "+3 this week" },
    { "label": "API routes", "value": "8", "delta": "config-driven" },
    { "label": "Database readiness", "value": "PostgreSQL", "delta": "Prisma schema included" }
  ],
  "forms": [
    {
      "id": "workspace-create",
      "title": "Create workspace",
      "description": "Provision a new generated app from the supplied JSON config.",
      "submitLabel": "Generate app",
      "fields": [
        { "name": "workspaceName", "label": "Workspace name", "type": "text", "placeholder": "Signal Ops" },
        { "name": "ownerEmail", "label": "Owner email", "type": "email", "placeholder": "sanoj@example.com" },
        { "name": "isPublic", "label": "Public preview", "type": "checkbox" }
      ]
    },
    {
      "id": "auth-signin",
      "title": "Demo auth",
      "description": "Basic sign-in flow for the generated app.",
      "submitLabel": "Sign in",
      "fields": [
        { "name": "email", "label": "Email", "type": "email", "placeholder": "demo@company.com" },
        { "name": "password", "label": "Password", "type": "password", "placeholder": "••••••••" }
      ]
    },
    {
      "id": "auth-signup",
      "title": "Create account",
      "description": "Config-driven signup form.",
      "submitLabel": "Sign up",
      "fields": [
        { "name": "email", "label": "Email", "type": "email", "placeholder": "new@company.com" },
        { "name": "password", "label": "Password", "type": "password", "placeholder": "minimum 4 chars" }
      ]
    },
    {
      "id": "auth-otp",
      "title": "OTP login",
      "description": "Request OTP and verify using the same form. Demo OTP is 123456.",
      "submitLabel": "Verify OTP",
      "fields": [
        { "name": "email", "label": "Email", "type": "email", "placeholder": "demo@company.com" },
        { "name": "otp", "label": "OTP", "type": "text", "placeholder": "123456" }
      ]
    }
  ],
  "tables": [
    {
      "id": "applications",
      "title": "Generated applications",
      "columns": [
        { "key": "name", "label": "App name" },
        { "key": "status", "label": "Status" },
